# =============================================================================
# AI Chronic Disease Management Agent System v2
# Environment Configuration
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Open .env and fill in your actual values
#   3. Never commit .env to git — add it to .gitignore
#   4. This file (.env.example) is safe to commit — it contains no real secrets
#
# IMPORTANT — CLINICAL DISCLAIMER:
#   This system is clinical decision support only.
#   All recommendations require review by a licensed healthcare provider.
#   In an emergency, call 911 immediately.
#   Do NOT use production patient data without HIPAA-compliant infrastructure.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — REQUIRED FOR LIVE MODE
# -----------------------------------------------------------------------------

# Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
# The key must start with sk- for the system to recognise it as valid.
# If this is missing or blank, the system runs in DEMO mode automatically —
# all agents produce structured care plans without live LLM reasoning.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model for all clinical agent LLM calls.
# Options:
#   gpt-4o         — recommended for clinical reasoning (default)
#   gpt-4o-mini    — cheaper, suitable for testing only
# Do NOT use a weaker model for production clinical reasoning.
# Default: gpt-4o
OPENAI_MODEL=gpt-4o

# LLM temperature — must be very low for clinical consistency.
# 0.0 = fully deterministic (safest for clinical decisions)
# 0.1 = minimal variation (default)
# Never set above 0.2 for a clinical agent.
# Default: 0.05
OPENAI_TEMPERATURE=0.05


# -----------------------------------------------------------------------------
# SYSTEM IDENTITY — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Name of the care system as it appears in all clinical reports and notifications.
# Default: CareCompanion AI
SYSTEM_NAME=CareCompanion AI

# Name of the healthcare organisation operating this system.
# Appears in all care plans, notifications, and audit logs.
# Default: Integrated Health Network
ORGANIZATION_NAME=Integrated Health Network


# -----------------------------------------------------------------------------
# HUMAN-IN-THE-LOOP (HITL) — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Minimum urgency level that requires human approval before dispatch.
# All actions at or above this level are held in the pending approval queue.
# Options:
#   routine    — only routine actions auto-execute; urgent + emergency require approval
#   urgent     — routine auto-executes; urgent + emergency require approval (default)
#   emergency  — routine + urgent auto-execute; only emergencies bypass HITL
# Recommended for production: urgent
# Default: urgent
HITL_APPROVAL_THRESHOLD=urgent

# Planning horizon — how many days of data the agents analyse per pass.
# Default: 7
PLANNING_HORIZON_DAYS=7


# -----------------------------------------------------------------------------
# CLINICAL THRESHOLDS — OPTIONAL (defaults shown)
# All values are used by the planner agent for deterministic signal detection.
# Change only if your clinical protocols differ from the defaults below.
# -----------------------------------------------------------------------------

# Glucose thresholds (mg/dL)
# Critical low — triggers EMERGENCY bypass, immediate alert
GLUCOSE_CRITICAL_LOW=54.0
# Low — below normal but not emergency
GLUCOSE_LOW=70.0
# High — above target range, triggers warning
GLUCOSE_TARGET_HIGH=180.0
# Critical high — possible DKA risk, triggers urgent alert
GLUCOSE_CRITICAL_HIGH=350.0

# Blood pressure thresholds (mmHg systolic)
# Consistently elevated — triggers physician alert
BP_SYSTOLIC_HIGH=140.0
# Hypertensive crisis — triggers EMERGENCY bypass
BP_SYSTOLIC_CRITICAL=180.0

# Heart rate thresholds (bpm)
# Critical low — triggers EMERGENCY bypass
HR_CRITICAL_LOW=45.0
# Critical high — triggers EMERGENCY bypass
HR_CRITICAL_HIGH=130.0

# SpO2 threshold (%)
# Critical low — triggers EMERGENCY bypass
SPO2_CRITICAL=88.0

# Medication adherence threshold (%)
# Below this level triggers a low adherence warning
ADHERENCE_LOW_PCT=60.0


# -----------------------------------------------------------------------------
# NOTIFICATION DISPATCH — OPTIONAL
# Production channels for sending clinical alerts to patients and care teams.
# Leave blank to run in demo mode (notifications are logged but not sent).
# -----------------------------------------------------------------------------

# Twilio — SMS and voice alerts to patients and care coordinators
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid — email alerts to care team and physicians
# Get API key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Firebase Cloud Messaging (FCM) — push notifications to patient mobile app
# Get server key from: https://console.firebase.google.com
FCM_SERVER_KEY=
FCM_PROJECT_ID=


# -----------------------------------------------------------------------------
# WEARABLE AND DEVICE DATA — OPTIONAL
# Production data sources for patient vitals.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# Fitbit Web API — heart rate, SpO2, weight, sleep stages
# Register your app at: https://dev.fitbit.com/apps/new
# Uses OAuth2 — access token per patient, refresh token handling required
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Garmin Health API — heart rate, SpO2, stress, body battery
# Apply for access at: https://developer.garmin.com/health-api/overview/
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=

# Withings Health API — blood pressure, weight, SpO2 (BPM Connect, ScanWatch)
# Register at: https://developer.withings.com/
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Omron Connect API — blood pressure monitor integration
# Contact: https://omronhealthcare.com/developer/
OMRON_API_KEY=


# -----------------------------------------------------------------------------
# CONTINUOUS GLUCOSE MONITORING (CGM) — OPTIONAL
# Production sources for glucose readings.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# Dexcom Share API — real-time CGM readings for Dexcom G6/G7 users
# Register at: https://developer.dexcom.com/
# Uses OAuth2 — patient must grant access via Dexcom Share
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=

# Abbott LibreView API — FreeStyle Libre CGM readings
# Contact Abbott for developer access: https://www.librelinkup.com/
LIBRE_CLIENT_ID=
LIBRE_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# MEDICATION ADHERENCE — OPTIONAL
# Production sources for medication tracking data.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# Medisafe API — smart pill dispenser and medication adherence tracking
# Contact: https://medisafe.com/developer/
MEDISAFE_API_KEY=

# Epic MyChart FHIR API — medication records from Epic EHR
# Requires SMART on FHIR OAuth2 registration with your Epic environment
# Register at: https://fhir.epic.com/Documentation?docId=oauth2
EPIC_FHIR_BASE_URL=
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=

# Cerner FHIR API — medication records from Cerner/Oracle Health EHR
CERNER_FHIR_BASE_URL=
CERNER_CLIENT_ID=
CERNER_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# LABORATORY RESULTS — OPTIONAL
# Production sources for lab data (HbA1c, eGFR, BNP, electrolytes).
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# HL7 FHIR R4 endpoint — generic FHIR server for lab results
# Used with Epic, Cerner, or any FHIR-compliant lab system
# LOINC codes used: HbA1c (4548-4), eGFR (62238-1),
#                   potassium (2823-3), BNP (42637-9)
FHIR_BASE_URL=
FHIR_ACCESS_TOKEN=

# Quest Diagnostics API — lab results direct from Quest
# Contact: https://www.questdiagnostics.com/business-solutions/life-sciences/api-solutions
QUEST_API_KEY=
QUEST_ORG_ID=

# Labcorp Patient API — lab results from Labcorp
# Contact: https://www.labcorp.com/patients/digital-health
LABCORP_API_KEY=


# -----------------------------------------------------------------------------
# SYMPTOM COLLECTION — OPTIONAL
# Production channel for collecting patient-reported symptoms between visits.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# Twilio — IVR (automated phone call) or SMS symptom check-in
# Uses same credentials as the notification section above.
# Leave blank if using the mobile app instead.
TWILIO_SYMPTOM_SURVEY_FLOW_SID=


# -----------------------------------------------------------------------------
# EHR INTEGRATION — OPTIONAL
# Used for writing care plan updates and clinical notes back to the EHR.
# Leave blank for standalone operation without EHR write-back.
# -----------------------------------------------------------------------------

# Epic InBasket API — send care plan tasks to physician InBasket
# Requires Epic production OAuth2 registration
EPIC_INBASKET_ENDPOINT=

# HL7 FHIR CareTeam and Goal resources — write care plan to FHIR server
# Uses same FHIR_BASE_URL and FHIR_ACCESS_TOKEN as lab results above
FHIR_WRITE_ENABLED=false


# -----------------------------------------------------------------------------
# LOGGING AND AUDIT — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Log level.
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during development, INFO in production.
# Default: INFO
LOG_LEVEL=INFO

# Audit log file path — every clinical decision, alert, and HITL action
# is written here for compliance and review.
# Leave blank to log to stdout only.
AUDIT_LOG_FILE=

# Retain audit logs for this many days before rotation.
# Recommended minimum for HIPAA compliance: 2190 (6 years)
# Default: 2190
AUDIT_LOG_RETENTION_DAYS=2190

